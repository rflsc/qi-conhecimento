# Produção — Atlas + Render + Vercel
# Copie os valores para o dashboard de cada plataforma (não commite secrets).

# ── Render (API) ──────────────────────────────────────────────
NODE_ENV=production
PORT=10000
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/qi-conhecimento?retryWrites=true&w=majority
# Redis — use Upstash grátis (https://upstash.com), NÃO Redis do Render (pago)
REDIS_URL=rediss://default:PASSWORD@xxx.upstash.io:6379
JWT_SECRET=gerar-string-aleatoria-longa-min-32-chars
JWT_EXPIRES_IN=15m
BCRYPT_ROUNDS=12

# Desative seeds em produção
SEED_ADMIN_ENABLED=false
SEED_KNOWLEDGE_ENABLED=false

# CORS — URLs dos frontends na Vercel (separadas por vírgula, sem barra final)
CORS_ORIGINS=https://seu-web.vercel.app,https://seu-admin.vercel.app

# RAG — configure chaves e provedores no admin → Configurações
API_CREDENTIALS_ENCRYPTION_KEY=gerar-com-openssl-rand-base64-32

# Integração Qi Agents — service key obrigatória em produção (header X-Service-Key)
# Gere uma string aleatória longa e cadastre a mesma no Qi Agents.
SERVICE_API_KEY=gerar-string-aleatoria-longa-min-32-chars

# Armazenamento — disco persistente no Render (render.yaml monta em /var/data/storage)
STORAGE_PATH=/var/data/storage
MAX_UPLOAD_SIZE_MB=150

# Parser opcional (Render Docker service ou omita para usar pdf-parse)
PARSER_SERVICE_URL=
PARSER_SERVICE_TIMEOUT_MS=7200000

# ── Vercel (apps/web) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://qi-conhecimento-api.onrender.com
NEXT_PUBLIC_ADMIN_URL=https://seu-admin.vercel.app

# ── Vercel (apps/admin) ─────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://qi-conhecimento-api.onrender.com
