# API
NODE_ENV=development
PORT=3100
MONGODB_URI=mongodb://localhost:27017/qi-conhecimento
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Seed — usuário admin inicial (apenas dev; desative em produção)
SEED_ADMIN_ENABLED=true
SEED_ADMIN_EMAIL=admin@altoqi.com.br
SEED_ADMIN_PASSWORD=AdminQi123!
SEED_ADMIN_NAME=Admin Qi

# Seed — conhecimento piloto (procedimentos NBR; apenas dev)
SEED_KNOWLEDGE_ENABLED=true

# Criptografia de credenciais salvas no painel (gere com: openssl rand -base64 32)
API_CREDENTIALS_ENCRYPTION_KEY=

# RAG / Embeddings — configure chaves e provedores no admin → Configurações
# Ollama (local) — URL do serviço quando embedding = ollama
OLLAMA_BASE_URL=http://localhost:11434
# EMBEDDING_CONCURRENCY=5   # jobs paralelos (default: 5 openai, 2 ollama)
VECTOR_INDEX_NAME=knowledge_chunks

# Ingestão multimodal
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=150

# Parser service (apps/parser — FastAPI + Docling). Vazio = usa pdf-parse local.
PARSER_SERVICE_URL=http://localhost:8000
PARSER_SERVICE_TIMEOUT_MS=7200000
PARSER_MAX_UPLOAD_MB=150

# Perfil de RAM do parser (apps/parser — lido via pnpm parser:dev)
# default | low_memory | high_memory (≥16–32 GB — 2 workers, lotes maiores)
PARSER_PROFILE=high_memory
# Sobrescrevem o perfil se definidos:
# PARSER_PARALLEL_WORKERS=2
# PARSER_PAGE_BATCH_SIZE=12
# PARSER_IMAGES_SCALE=1.0
# PARSER_TABLE_MODE=accurate
# PARSER_TABLE_IMAGE_RECOVERY=true

# Mensageria — Pilar 3 (Interface de Campo)
# Service key serviço-a-serviço para integração Qi Agents (header X-Service-Key).
# Vazio em dev = rota /messaging/query aberta. Defina em produção.
SERVICE_API_KEY=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
TELEGRAM_BOT_TOKEN=

# Web / Admin
NEXT_PUBLIC_API_URL=http://localhost:3100
NEXT_PUBLIC_ADMIN_URL=http://localhost:3102
# Login pré-preenchido no admin (dev — espelha SEED_ADMIN_*)
NEXT_PUBLIC_DEV_LOGIN_EMAIL=admin@altoqi.com.br
NEXT_PUBLIC_DEV_LOGIN_PASSWORD=AdminQi123!

# CORS (API) — origens permitidas, separadas por vírgula (produção)
# CORS_ORIGINS=https://seu-web.vercel.app,https://seu-admin.vercel.app
