# API
NODE_ENV=development
PORT=3100
MONGODB_URI=mongodb://localhost:27017/qi-conhecimento
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Seed — usuário admin inicial (apenas dev; desative em produção)
SEED_ADMIN_ENABLED=true
SEED_ADMIN_EMAIL=admin@altoqi.com.br
SEED_ADMIN_PASSWORD=AdminQi123!
SEED_ADMIN_NAME=Admin Qi

# Seed — conhecimento piloto (procedimentos NBR; apenas dev)
SEED_KNOWLEDGE_ENABLED=true

# RAG / Embeddings (Pilar 2)
# Provedor: openai (pago) | ollama (local/grátis — recomendado para dev)
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
OPENAI_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small  # quando EMBEDDING_PROVIDER=openai

# LLM para respostas RAG (openai | anthropic — auto-detecta pela key disponível)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
VECTOR_INDEX_NAME=knowledge_chunks

# Ingestão multimodal
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE_MB=50

# Parser service (apps/parser — FastAPI + Docling). Vazio = usa pdf-parse local.
PARSER_SERVICE_URL=http://localhost:8000
PARSER_SERVICE_TIMEOUT_MS=120000

# Mensageria — Pilar 3 (Interface de Campo)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
TELEGRAM_BOT_TOKEN=

# Web / Admin
NEXT_PUBLIC_API_URL=http://localhost:3100
NEXT_PUBLIC_ADMIN_URL=http://localhost:3102

# CORS (API) — origens permitidas, separadas por vírgula (produção)
# CORS_ORIGINS=https://seu-web.vercel.app,https://seu-admin.vercel.app
